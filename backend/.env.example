# ── Database ──────────────────────────────────────────────────────────────────
# Local Docker:
DATABASE_URL=postgresql+asyncpg://sentinel:sentinelpassword@localhost:5432/sentinel_db
# Supabase (transaction pooler, port 6543):
# DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<pass>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local Docker:
REDIS_URL=redis://localhost:6379/0
# Upstash (note: rediss:// for TLS):
# REDIS_URL=rediss://default:<pass>@<host>.upstash.io:6379

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_USE_SASL=false
KAFKA_USERNAME=
KAFKA_PASSWORD=
# Aiven Kafka (hosted):
# KAFKA_ENABLED=true
# KAFKA_BOOTSTRAP_SERVERS=<service>.aivencloud.com:26161
# KAFKA_USE_SASL=true
# KAFKA_USERNAME=avnadmin
# KAFKA_PASSWORD=<password>

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED: minimum 32 characters
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_MINIMUM_32_CHARACTERS_REQUIRED_HERE_NOW

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2:3b

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT_NAME=sentinel

# ── Observability ─────────────────────────────────────────────────────────────
JAEGER_HOST=localhost
JAEGER_PORT=6831
PROMETHEUS_ENABLED=true

# ── Notifications (optional) ──────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_FROM=
SMTP_PASSWORD=

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=DEBUG
CORS_ORIGINS=["http://localhost:3000"]
